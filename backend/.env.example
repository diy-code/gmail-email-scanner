# Phase 0 — Local development environment variables
# Copy this file to .env and fill in your real API keys.
# .env is never committed to git (add it to .gitignore).
# On Cloud Run, these are set via --set-env-vars in the gcloud deploy command.

VIRUSTOTAL_API_KEY=your_virustotal_api_key_here
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here
SAFE_BROWSING_API_KEY=your_google_safe_browsing_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Shared secret — must match what is stored in Apps Script PropertiesService
API_KEY=your_backend_api_key_here

# Optional
APP_VERSION=1.0.0
LOG_LEVEL=INFO
SIGNAL_TIMEOUT_SECONDS=3.0
VIRUSTOTAL_MAX_DOMAINS=3
MAX_URLS_PER_REQUEST=10
